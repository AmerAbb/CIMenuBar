default_platform(:mac)

platform :mac do
  desc "Release a new version. Usage: fastlane release bump:patch (or minor/major)"
  lane :release do |options|
    bump_type = options[:bump] || "patch"
    root = File.expand_path("..", __dir__)
    project_file = File.join(root, "project.yml")

    # Read current version from project.yml
    project_yml = File.read(project_file)
    current_version = project_yml.match(/MARKETING_VERSION: "(\d+\.\d+\.\d+)"/)[1]
    UI.message("Current version: #{current_version}")

    # Calculate new version
    major, minor, patch = current_version.split(".").map(&:to_i)
    case bump_type
    when "major"
      major += 1
      minor = 0
      patch = 0
    when "minor"
      minor += 1
      patch = 0
    when "patch"
      patch += 1
    else
      UI.user_error!("Invalid bump type '#{bump_type}'. Use: patch, minor, or major")
    end
    new_version = "#{major}.#{minor}.#{patch}"
    UI.message("Bumping to: #{new_version}")

    # Update both version strings in project.yml
    updated_yml = project_yml
      .gsub(/MARKETING_VERSION: "#{current_version}"/, "MARKETING_VERSION: \"#{new_version}\"")
      .gsub(/CURRENT_PROJECT_VERSION: "#{current_version}"/, "CURRENT_PROJECT_VERSION: \"#{new_version}\"")
    File.write(project_file, updated_yml)

    # Commit, tag, push — GitHub Actions handles the rest
    Dir.chdir(root) do
      sh("git", "add", "project.yml")
      sh("git", "commit", "-m", "Bump version to #{new_version}")
      sh("git", "tag", "v#{new_version}")
      sh("git", "push", "origin", "main", "--tags")
    end

    UI.success("v#{new_version} tagged and pushed — GitHub Actions will build and release")
  end
end
